# DecisionBox Agent Configuration

# --- Service ---
ENV=dev
LOG_LEVEL=info
SERVICE_NAME=decisionbox-agent

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=decisionbox

# --- Data Warehouse ---
# Provider: bigquery (more coming: postgres, clickhouse)
WAREHOUSE_PROVIDER=bigquery
WAREHOUSE_PROJECT_ID=your-gcp-project
WAREHOUSE_DATASET=your_dataset
WAREHOUSE_LOCATION=US
WAREHOUSE_TIMEOUT=5m

# --- LLM Provider ---
# Available providers:
#   claude    - Direct Anthropic API (requires LLM_API_KEY)
#   openai    - Direct OpenAI API (requires LLM_API_KEY)
#   ollama    - Local Ollama instance (requires OLLAMA_HOST)
#   vertex-ai - Google Vertex AI (requires VERTEX_PROJECT_ID, GCP credentials) [stub]
#   bedrock   - AWS Bedrock (requires AWS credentials) [stub]

LLM_PROVIDER=claude
LLM_API_KEY=your-api-key
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_RETRIES=3
LLM_TIMEOUT=60s
LLM_REQUEST_DELAY_MS=2000

# --- OpenAI-specific ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1  # optional, for compatible APIs

# --- Ollama-specific ---
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b
# OLLAMA_HOST=http://localhost:11434

# --- Vertex AI-specific (stub) ---
# LLM_PROVIDER=vertex-ai
# LLM_MODEL=claude-sonnet-4-20250514
# VERTEX_PROJECT_ID=your-gcp-project
# VERTEX_LOCATION=us-east5

# --- Bedrock-specific (stub) ---
# LLM_PROVIDER=bedrock
# LLM_MODEL=anthropic.claude-sonnet-4-20250514-v1:0
# AWS_REGION=us-east-1

# --- Discovery ---
DISCOVERY_MAX_STEPS=100
DISCOVERY_MAX_SQL_RETRIES=5
DISCOVERY_TIMEOUT_PER_STEP=5m
DISCOVERY_ENABLE_CONTEXT_LEARNING=true
DISCOVERY_MIN_PATTERN_USERS=50
